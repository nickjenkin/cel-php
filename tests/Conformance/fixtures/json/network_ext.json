{"name":"network_ext","description":"Conformance tests for IP address extensions in CEL","section":[{"name":"ip_type","description":"Tests for parsing and validating IP addresses","test":[{"name":"parse_ipv4","description":"Successfully parse a standard IPv4 address","expr":"string(ip('192.168.0.1'))","value":{"stringValue":"192.168.0.1"}},{"name":"parse_invalid_ipv4","description":"Fail to parse an invalid IPv4 address","expr":"ip('192.168.0.1.0')","evalError":{"errors":[{"message":"IP Address '192.168.0.1.0' parse error during conversion from string"}]}},{"name":"is_ip_valid_ipv4","description":"isIP returns true for valid IPv4","expr":"isIP('192.168.0.1')","value":{"boolValue":true}},{"name":"is_ip_invalid_ipv4","description":"isIP returns false for invalid IPv4","expr":"isIP('192.168.0.1.0')","value":{"boolValue":false}},{"name":"ip_is_canonical_valid_ipv4","description":"ip.isCanonical returns true for valid IPv4","expr":"ip.isCanonical('127.0.0.1')","value":{"boolValue":true}},{"name":"ip_is_canonical_invalid_ipv4","description":"ip.isCanonical errors on invalid address string","expr":"ip.isCanonical('127.0.0.1.0')","evalError":{"errors":[{"message":"IP Address '127.0.0.1.0' parse error during conversion from string"}]}},{"name":"ip_is_canonical_non_canonical_ipv6","description":"IPv6 with uppercase letters is not canonical","expr":"ip.isCanonical('2001:DB8::68')","value":{"boolValue":false}},{"name":"parse_ipv6","expr":"string(ip('2001:db8::68'))","value":{"stringValue":"2001:db8::68"}},{"name":"parse_invalid_ipv6","expr":"ip('2001:db8:::68')","evalError":{"errors":[{"message":"IP Address '2001:db8:::68' parse error"}]}},{"name":"parse_invalid_ipv6_with_zone","expr":"ip('fe80::1%en0')","evalError":{"errors":[{"message":"IP Address with zone value is not allowed"}]}},{"name":"parse_invalid_ipv4_in_ipv6","expr":"ip('::ffff:192.168.0.1')","evalError":{"errors":[{"message":"IPv4-mapped IPv6 address is not allowed"}]}},{"name":"ip_to_string","description":"Converting an IP address back to a string","expr":"string(ip('192.168.0.1'))","value":{"stringValue":"192.168.0.1"}},{"name":"ip_type","description":"Check the type of the IP object","expr":"type(ip('192.168.0.1')) == net.IP","value":{"boolValue":true}},{"name":"is_ip_cidr_compile_error","description":"isIP should not accept a CIDR type","expr":"isIP(cidr('192.168.0.0/24'))","evalError":{"errors":[{"message":"found no matching overload for 'isIP' applied to '(net.CIDR)'"}]}}]},{"name":"ipv4","description":"Tests for properties and methods of IPv4 addresses","test":[{"name":"ipv4_family","expr":"ip('192.168.0.1').family()","value":{"int64Value":"4"}},{"name":"ipv4_is_unspecified_true","expr":"ip('0.0.0.0').isUnspecified()","value":{"boolValue":true}},{"name":"ipv4_is_unspecified_false","expr":"ip('127.0.0.1').isUnspecified()","value":{"boolValue":false}},{"name":"ipv4_is_loopback_true","expr":"ip('127.0.0.1').isLoopback()","value":{"boolValue":true}},{"name":"ipv4_is_loopback_false","expr":"ip('1.2.3.4').isLoopback()","value":{"boolValue":false}},{"name":"ipv4_is_global_unicast_true","expr":"ip('192.168.0.1').isGlobalUnicast()","value":{"boolValue":true}},{"name":"ipv4_is_global_unicast_false","expr":"ip('255.255.255.255').isGlobalUnicast()","value":{"boolValue":false}},{"name":"is_link_local_multicast_true","expr":"ip('224.0.0.1').isLinkLocalMulticast()","value":{"boolValue":true}},{"name":"is_link_local_multicast_false","expr":"ip('224.0.1.1').isLinkLocalMulticast()","value":{"boolValue":false}},{"name":"is_link_local_unicast_true","expr":"ip('169.254.169.254').isLinkLocalUnicast()","value":{"boolValue":true}},{"name":"is_link_local_unicast_false","expr":"ip('192.168.0.1').isLinkLocalUnicast()","value":{"boolValue":false}},{"name":"ipv4_equals","expr":"ip('127.0.0.1') == ip('127.0.0.1')","value":{"boolValue":true}},{"name":"ipv4_not_equals","expr":"ip('127.0.0.1') == ip('10.0.0.1')","value":{"boolValue":false}},{"name":"ipv4_equals_ipv6","expr":"ip('::ffff:c0a8:1') == ip('192.168.0.1')","value":{"boolValue":true}},{"name":"ipv4_not_equals_ipv6","expr":"ip('::ffff:c0a8:1') == ip('192.168.10.1')","value":{"boolValue":false}}]},{"name":"ipv6","description":"Tests for properties and methods of IPv6 addresses","test":[{"name":"family","expr":"ip('2001:db8::68').family()","value":{"int64Value":"6"}},{"name":"is_unspecified_true","expr":"ip('::').isUnspecified()","value":{"boolValue":true}},{"name":"is_loopback_true","expr":"ip('::1').isLoopback()","value":{"boolValue":true}},{"name":"is_global_unicast_true","expr":"ip('2001:db8::abcd').isGlobalUnicast()","value":{"boolValue":true}},{"name":"is_global_unicast_false","expr":"ip('ff00::1').isGlobalUnicast()","value":{"boolValue":false}},{"name":"is_link_local_multicast_true","expr":"ip('ff02::1').isLinkLocalMulticast()","value":{"boolValue":true}},{"name":"is_link_local_multicast_false","expr":"ip('fd00::1').isLinkLocalMulticast()","value":{"boolValue":false}},{"name":"is_link_local_unicast_true","expr":"ip('fe80::1').isLinkLocalUnicast()","value":{"boolValue":true}},{"name":"is_link_local_unicast_false","expr":"ip('fd80::1').isLinkLocalUnicast()","value":{"boolValue":false}},{"name":"ipv6_equals","expr":"ip('2001:db8::1') == ip('2001:DB8::1')","value":{"boolValue":true}},{"name":"ipv6_not_equals","expr":"ip('::') == ip('::ffff')","value":{"boolValue":false}}]},{"name":"cidr","description":"Tests for CIDR parsing and range checking","test":[{"name":"parse_cidr_ipv4","expr":"type(cidr('192.168.0.0/24')) == net.CIDR","value":{"boolValue":true}},{"name":"parse_invalid_cidr_ipv4","expr":"cidr('192.168.0.0/')","evalError":{"errors":[{"message":"network address parse error during conversion from string"}]}},{"name":"parse_invalid_cidr_with_zone","expr":"cidr('fe80::1%en0/24')","evalError":{"errors":[{"message":"CIDR with zone value is not allowed"}]}},{"name":"parse_invalid_cidr_ipv4_in_ipv6","expr":"cidr('::ffff:192.168.0.1/24')","evalError":{"errors":[{"message":"IPv4-mapped IPv6 address is not 